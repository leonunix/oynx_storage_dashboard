ONYX_DASHBOARD_ADDR=:8080
ONYX_DASHBOARD_ALLOWED_ORIGINS=http://localhost:5173
ONYX_DASHBOARD_JWT_SECRET=change-me-in-production
ONYX_DASHBOARD_TOKEN_TTL_HOURS=12
ONYX_DASHBOARD_ADMIN_USER=admin
ONYX_DASHBOARD_ADMIN_PASSWORD=onyx-admin
ONYX_DASHBOARD_ADMIN_ROLE=admin
ONYX_DASHBOARD_DB_PATH=var/dashboard.db
ONYX_STORAGE_BIN=onyx-storage
ONYX_STORAGE_CONFIG=config/default.toml
ONYX_STORAGE_SOCKET=/var/run/onyx-storage.sock
ONYX_DASHBOARD_EXEC_TIMEOUT_SECONDS=10
ONYX_DASHBOARD_STORAGE_OP_TIMEOUT_SECONDS=120
ONYX_DASHBOARD_ALLOW_DM_MUTATIONS=false
